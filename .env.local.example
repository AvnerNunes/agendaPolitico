# Copie este arquivo para .env.local e preencha com os valores reais.
# .env.local NUNCA deve ser commitado (já está no .gitignore).

# Vercel Blob — gerado automaticamente ao criar o store, ou copiado manualmente
BLOB_READ_WRITE_TOKEN=

# Senha inventada por você, usada pra proteger a rota de upload manual
UPLOAD_SECRET=

# Número autorizado a mandar mensagens pro robô (só dígitos, com código do país, sem o "+")
# Exemplo: 5511999999999
ALLOWED_PHONE=

# Dados da instância do Z-API (painel Z-API > Instâncias Web)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=

# Client-Token da conta Z-API (painel Z-API > Segurança)
ZAPI_CLIENT_TOKEN=
