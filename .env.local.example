# Copie este arquivo para .env.local e preencha com os valores reais.
# .env.local NUNCA deve ser commitado (já está no .gitignore).

# Vercel Blob — gerado automaticamente ao criar o store, ou copiado manualmente
BLOB_READ_WRITE_TOKEN=

# Senha inventada por você, usada pra proteger a rota de upload manual
UPLOAD_SECRET=

# ID do grupo de WhatsApp autorizado (formato: 123456789-123456@g.us)
# Aceita mensagens de dentro do grupo, E mensagens privadas de quem for membro dele
ALLOWED_GROUP_ID=

# Token da API da Whapi Cloud (painel Whapi > seu canal > API Token)
WHAPI_TOKEN=
